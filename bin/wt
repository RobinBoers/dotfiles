#!/bin/sh
# git worktree workflow with per-repo setup hooks.

set -eu

: "${WT_PROJECTS_DIR:=$HOME/projects/qdentity}"
: "${WT_WORKTREES_DIR:=$WT_PROJECTS_DIR/worktrees}"
: "${WT_STATE_DIR:=${XDG_STATE_HOME:-$HOME/.local/state}/wt}"
: "${WT_HOOKS_DIR:=${XDG_CONFIG_HOME:-$HOME/.config}/wt/hooks}"
: "${WT_PREFIX:=}"

usage() {
	echo "Usage: $(basename "$0") <subcommand> [opts]"
	echo
	echo "SUBCOMMANDS"
	echo "  list, ls                 List worktrees."
	echo "  checkout, co <name>      Check out a worktree."
	echo "  remove, rm <name>        Remove a worktree."
	echo "  launch [name]            Open IDE for a worktree."
	echo "  prune, pr                Prune worktrees without a remote."
	echo
	echo "HOOKS"
	echo "  setup                    Run setup hook for current worktree."
	echo "  teardown                 Run teardown hook for current worktree."
	echo
	echo "LIST OPTIONS"
	echo "  -a                       List all repos, not just the current."
	echo "  -A                       Also include repos with no worktrees."
	echo
	echo "CHECKOUT OPTIONS"
	echo "  -b, --branch             Initialize a new worktree."
	echo "  -F, --fork               Fork the current worktree."
	echo
	echo "PRUNE OPTIONS"
	echo "  -a                       Prune all repos, not just the current."
	echo "  -A                       Also include repos with no worktrees."
	echo "  -n, --dry-run            Show what would be pruned."
	echo "  -f, --force              Skip confirmation prompts."
	echo
	echo "SHELL INTEGRATION"
	echo "  source <shell>           Injects shell integration."
	echo "  completions <shell>      Injects shell completions."
	echo
	exit 0
}

# Exported as the contract for setup/teardown hooks.
export WT_REPO_NAME WT_REPO_PATH WT_BRANCH_NAME WT_BRANCH_PATH

# ANSI styling, only when stdout is a terminal and NO_COLOR is unset.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
	BOLD=$(printf '\033[1m'); DIM=$(printf '\033[2m')
	RED=$(printf '\033[31m'); GREEN=$(printf '\033[32m'); ORANGE=$(printf '\033[38;5;208m')
	RESET=$(printf '\033[0m')
else
	BOLD= DIM= RED= GREEN= ORANGE= RESET=
fi

resolve_repo() {
	IN_REPO=0
	common=$(git rev-parse --git-common-dir 2>/dev/null) || return 0
	common=$(cd "$common" && pwd)
	WT_REPO_PATH=$(dirname "$common")
	WT_REPO_NAME=$(basename "$WT_REPO_PATH")
	IN_REPO=1
}

resolve_worktree() {
	resolve_repo

	name=$1

	if [ "$IN_REPO" -eq 1 ]; then
		branch=$name
	else
		case "$name" in
			*/*) WT_REPO_NAME=${name%%/*}; branch=${name#*/} ;;
			*) err "expected <repo>/<branch>" ;;
		esac

		WT_REPO_PATH=$WT_PROJECTS_DIR/$WT_REPO_NAME

		if [ ! -d "$WT_REPO_PATH/.git" ]; then
			err "no such repo '$WT_REPO_NAME' in $WT_PROJECTS_DIR"
		fi
	fi

	WT_BRANCH_NAME_REMOTE=$branch # may contain slashes
	WT_BRANCH_NAME=$(sluggify "$branch") # only contains dashes
	WT_BRANCH_PATH=$WT_WORKTREES_DIR/$WT_REPO_NAME/$WT_BRANCH_NAME
}

do_checkout() {
	create=0 fork=0 start="" name=""
	while [ $# -gt 0 ]; do
		case "$1" in
		-b|--branch) create=1 ;;
		-F|--fork) fork=1 ;;
		-bF) create=1; fork=1 ;;
		-Fb) fork=1; create=1 ;;
		-*) err "checkout: unknown option '$1'" ;;
		*) if [ -z "$name" ]; then name=$1; else start=$1; fi ;;
		esac
		shift
	done

	if [ -z "$name" ]; then
		err "checkout: specify a name"
	fi

	if [ "$fork" -eq 1 ] && [ "$create" -eq 0 ]; then
		err "checkout: --fork requires --branch"
	fi

	if [ "$create" -eq 1 ]; then
		case "$name" in
			"$WT_PREFIX"*) ;;
			*) name="$WT_PREFIX$name" ;;
		esac
	fi

	resolve_worktree "$name"

	existing=$(worktree_for_branch "$WT_BRANCH_NAME")

	if [ -n "$existing" ]; then
		if [ "$create" -eq 1 ]; then
			err "checkout: branch '$WT_BRANCH_NAME' already exists at $existing"
		fi

		request_cd "$existing"
		return 0
	fi

	if [ "$create" -eq 1 ]; then
		if branch_exists "$WT_BRANCH_NAME"; then
			err "checkout: branch '$WT_BRANCH_NAME' already exists"
		fi

		if [ "$fork" -eq 1 ]; then
			if [ "$IN_REPO" -eq 0 ]; then
				err "checkout: run --fork inside a worktree"
			fi

			base=$(git rev-parse HEAD)
		elif [ -n "$start" ]; then
			base=$start
		else
			git_p fetch --quiet origin master || true
			base=origin/master
		fi
		git_p worktree add --no-track -b "$WT_BRANCH_NAME" "$WT_BRANCH_PATH" "$base"
	elif branch_exists "$WT_BRANCH_NAME"; then
		git_p worktree add "$WT_BRANCH_PATH" "$WT_BRANCH_NAME"
	elif git_p fetch --quiet origin "$WT_BRANCH_NAME_REMOTE" 2>/dev/null &&
		git_p show-ref --verify --quiet "refs/remotes/origin/$WT_BRANCH_NAME_REMOTE"; then
		git_p worktree add --track -b "$WT_BRANCH_NAME" "$WT_BRANCH_PATH" "origin/$WT_BRANCH_NAME_REMOTE"
	else
		err "checkout: no such branch '$WT_BRANCH_NAME_REMOTE'"
	fi

	run_hook setup

	request_cd "$WT_BRANCH_PATH"
}

do_list() {
	all=0 include_empty=0
	case "${1:-}" in
		"") ;;
		-a) all=1 ;;
		-A) all=1; include_empty=1 ;;
		*)  err "list: unknown option '$1'" ;;
	esac

	resolve_repo

	if [ "$all" -eq 0 ] && [ "$IN_REPO" -eq 1 ]; then
		do_list_repo
		return 0
	fi

	# List every clone under $WT_PROJECTS_DIR.
	for WT_REPO_PATH in "$WT_PROJECTS_DIR"/*/; do
		WT_REPO_PATH=${WT_REPO_PATH%/}
		[ -d "$WT_REPO_PATH/.git" ] || continue

		if [ "$include_empty" -eq 0 ] && ! has_worktrees; then
			continue
		fi

		WT_REPO_NAME=$(basename "$WT_REPO_PATH")
		printf '%s%s%s\n' "$BOLD" "$WT_REPO_NAME" "$RESET"
		do_list_repo
		echo
	done
}

do_list_repo() {
	git_p worktree list --porcelain | awk '/^worktree /{print $2}' | while read -r p; do
		br=$(git -C "$p" rev-parse --abbrev-ref HEAD 2>/dev/null || echo '?')

		dirty=$(git -C "$p" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
		if [ "$dirty" -gt 0 ]; then
			flag="dirty($dirty)"; flag_c="$ORANGE$flag$RESET"
		else
			flag="clean"; flag_c="$GREEN$flag$RESET"
		fi

		if counts=$(git -C "$p" rev-list --left-right --count '@{u}...HEAD' 2>/dev/null); then
			behind=$(printf '%s' "$counts" | cut -f1)
			ahead=$(printf '%s' "$counts" | cut -f2)
			if [ "$behind" -eq 0 ] && [ "$ahead" -eq 0 ]; then
				ab="up to date"; ab_c="$DIM$ab$RESET"
			else
				ab="-$behind +$ahead"; ab_c="$RED-$behind$RESET $GREEN+$ahead$RESET"
			fi
		else
			ab="no upstream"; ab_c="$DIM$ab$RESET"
		fi

		# Pad the colored fields by their visible width; printf counts escapes.
		printf '%-24s %s%*s %s%*s %s\n' \
			"$br" \
			"$flag_c" $((10 - ${#flag})) "" \
			"$ab_c" $((12 - ${#ab})) "" \
			"$p"
	done
}


do_remove() {
	if [ -z "${1:-}" ]; then
		err "remove: specify worktree"
	fi

	resolve_worktree "$1"

	if ! worktree_exists "$WT_BRANCH_PATH"; then
		err "remove: no such worktree '$WT_BRANCH_NAME'"
	fi

	prompt -y "Remove worktree $WT_BRANCH_PATH?" || return 0

	run_hook teardown

	if ! git_p worktree remove "$WT_BRANCH_PATH" 2>/dev/null; then
		prompt -n "Worktree is dirty, force remove?" || return 0
		git_p worktree remove --force "$WT_BRANCH_PATH"
	fi

	if branch_exists "$WT_BRANCH_NAME" && prompt -y "Remove branch '$WT_BRANCH_NAME'?"; then
		git_p branch -d "$WT_BRANCH_NAME" || git_p branch -D "$WT_BRANCH_NAME"
	fi
}

do_prune() {
	dry_run=0 force=0 all=0 include_empty=0
	while [ $# -gt 0 ]; do
		case "$1" in
		-n|--dry-run) dry_run=1 ;;
		-f|--force) force=1 ;;
		-a) all=1 ;;
		-A) all=1; include_empty=1 ;;
		-*) err "prune: unknown option '$1'" ;;
		esac
		shift
	done

	resolve_repo

	if [ "$all" -eq 1 ] || [ "$IN_REPO" -eq 0 ]; then
		for WT_REPO_PATH in "$WT_PROJECTS_DIR"/*/; do
			WT_REPO_PATH=${WT_REPO_PATH%/}
			[ -d "$WT_REPO_PATH/.git" ] || continue
			WT_REPO_NAME=$(basename "$WT_REPO_PATH")
			if has_worktrees; then
				do_prune_repo "$dry_run" "$force"
			elif [ "$include_empty" -eq 1 ]; then
				do_prune_branches "$dry_run" "$force"
			fi
		done
	else
		do_prune_repo "$dry_run" "$force"
	fi
}

do_prune_repo() {
	dry_run=$1 force=$2

	git_p fetch --quiet --all --prune 2>/dev/null || true

	git_p for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads | \
	awk '/ \[gone\]$/{print $1}' | while read -r WT_BRANCH_NAME; do
		WT_BRANCH_PATH=$(worktree_for_branch "$WT_BRANCH_NAME")

		[ -n "$WT_BRANCH_PATH" ] || continue

		if [ "$dry_run" -eq 1 ]; then
			printf 'would prune: %s\n  %s\n' "$WT_BRANCH_NAME" "$WT_BRANCH_PATH"
			continue
		fi

		if [ "$force" -eq 0 ] && ! prompt -y "Prune worktree '$WT_BRANCH_NAME'?"; then
			continue
		fi

		run_hook teardown

		if ! git_p worktree remove "$WT_BRANCH_PATH" 2>/dev/null; then
			if [ "$force" -eq 1 ] || prompt -n "Worktree is dirty, force remove?"; then
				git_p worktree remove --force "$WT_BRANCH_PATH"
			else
				continue
			fi
		fi

		git_p branch -d "$WT_BRANCH_NAME" 2>/dev/null || git_p branch -D "$WT_BRANCH_NAME"
	done
}

do_prune_branches() {
	dry_run=$1 force=$2

	git_p fetch --quiet --all --prune 2>/dev/null || true

	git_p for-each-ref --format='%(refname:short) %(upstream:track)' refs/heads | \
	awk '/ \[gone\]$/{print $1}' | while read -r branch; do
		if [ "$dry_run" -eq 1 ]; then
			printf 'would delete: %s\n' "$branch"
			continue
		fi

		if [ "$force" -eq 0 ] && ! prompt -y "Delete branch '$branch'?"; then
			continue
		fi

		git_p branch -D "$branch"
	done
}

do_launch() {
	if [ "${1:-}" ]; then
		resolve_worktree "$1"
		path=$WT_BRANCH_PATH
	else
		resolve_repo

		if [ "$IN_REPO" -eq 0 ]; then
			err "launch: specify worktree"
		fi

		path=$PWD
		WT_BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
	fi

	if ! worktree_exists "$path"; then
		err "launch: no worktree at $path"
	fi

	case "$(uname -s)" in
		Darwin)
			code "$path"
			terminal -c "$path" -e claude
			;;

		Linux)
			# Fresh sway workspace, editor first so claude can autodectec IDE, then focus
			# the Claude terminal. Window assignment relies on the active workspace.

			swaymsg "workspace $WT_REPO_NAME/$WT_BRANCH_NAME" >/dev/null
			code "$path"
			terminal -c "$path" -e claude
			;;

		*) err "launch: unsupported OS" ;;
	esac
}

# Helpers

git_p() { git -C "$WT_REPO_PATH" "$@"; }

branch_exists() { git_p show-ref --verify --quiet "refs/heads/$1"; }
worktree_exists() { git_p worktree list --porcelain | grep -Fqx "worktree $1"; }
has_worktrees() { [ "$(git_p worktree list --porcelain | grep -c '^worktree ')" -gt 1 ]; }

# Path of the worktree that has <branch> checked out, if any.
worktree_for_branch() {
	git_p worktree list --porcelain | awk -v b="refs/heads/$1" '
		/^worktree /{p=substr($0, 10)}
		$0 == "branch " b {print p; exit}
	'
}

do_run_hook() {
	resolve_repo
	[ "$IN_REPO" -eq 1 ] || err "${1}: run inside a worktree"
	WT_BRANCH_PATH=$(git rev-parse --show-toplevel)
	WT_BRANCH_NAME=$(git -C "$WT_BRANCH_PATH" rev-parse --abbrev-ref HEAD)
	(
		cd "$WT_BRANCH_PATH"
		run_hook "$1"
	)
}

run_hook() {
	# Per-repo hook if the repo has its own folder, else the shared default.
	if [ -d "$WT_HOOKS_DIR/$WT_REPO_NAME" ]; then
		hook=$WT_HOOKS_DIR/$WT_REPO_NAME/$1
	else
		hook=$WT_HOOKS_DIR/$1
	fi
	[ -x "$hook" ] || return 0
	"$hook"
}

# Completion

list_branches() {
	# Local heads + remote branches (origin/ stripped), like `git checkout` offers.

	git -C "$1" for-each-ref --format='%(refname)' refs/heads refs/remotes 2>/dev/null | grep -v '/HEAD$' | sed -e 's|^refs/heads/||' -e 's|^refs/remotes/[^/]*/||' | sort -u
}

list_worktrees() {
	# Branch names of the repo's existing worktrees.

	git -C "$1" worktree list --porcelain | awk '/^branch /{sub("refs/heads/", "", $2); print $2}'
}

do_complete() {
	case "${1:-}" in
		commands) printf '%s\n' list ls checkout co remove rm prune launch setup teardown ;;
		branches) complete_targets branches "${2:-}" ;;
		worktrees) complete_targets worktrees "${2:-}" ;;
	esac
}

do_completions() {
	case "${1:-}" in
		zsh)
			cat <<-'EOF'
				_wt() {
					if (( CURRENT == 2 )); then
						compadd -- ${(f)"$(command wt complete commands)"}
					else
						case $words[2] in
							co|checkout) compadd -- ${(f)"$(command wt complete branches "$words[CURRENT]")"} ;;
							rm|remove|launch) compadd -- ${(f)"$(command wt complete worktrees "$words[CURRENT]")"} ;;
							source|completions) compadd -- bash zsh fish ;;
						esac
					fi
				}
				compdef _wt wt
			EOF
			;;

		bash)
			cat <<-'EOF'
				_wt() {
					local cur=${COMP_WORDS[COMP_CWORD]}
					if [ "$COMP_CWORD" -eq 1 ]; then
						COMPREPLY=( $(compgen -W "$(command wt complete commands)" -- "$cur") )
					else
						case ${COMP_WORDS[1]} in
							co|checkout) COMPREPLY=( $(compgen -W "$(command wt complete branches "$cur")" -- "$cur") ) ;;
							rm|remove|launch) COMPREPLY=( $(compgen -W "$(command wt complete worktrees "$cur")" -- "$cur") ) ;;
							source|completions) COMPREPLY=( $(compgen -W "bash zsh fish" -- "$cur") ) ;;
						esac
					fi
				}
				complete -F _wt wt
			EOF
			;;

		fish)
			cat <<-'EOF'
				complete -c wt -f
				complete -c wt -n __fish_use_subcommand -a '(wt complete commands)'
				complete -c wt -n '__fish_seen_subcommand_from co checkout' -a '(wt complete branches (commandline -ct))'
				complete -c wt -n '__fish_seen_subcommand_from rm remove launch' -a '(wt complete worktrees (commandline -ct))'
				complete -c wt -n '__fish_seen_subcommand_from source completions' -a 'bash zsh fish'
			EOF
			;;

		*) err "completions: unknown shell '${1:-}' (bash|zsh|fish)" ;;
	esac
}

complete_targets() {
	kind=$1 current=${2:-}

	resolve_repo

	if [ "$IN_REPO" -eq 1 ]; then
		list_$kind "$WT_REPO_PATH"
		return 0
	fi

	case "$current" in
		*/*)
			repo=${current%%/*}
			[ -d "$WT_PROJECTS_DIR/$repo/.git" ] &&
				list_$kind "$WT_PROJECTS_DIR/$repo" | sed "s|^|$repo/|"
			;;
		*)
			for d in "$WT_PROJECTS_DIR"/*/; do
				d=${d%/}
				[ -d "$d/.git" ] && printf '%s/\n' "$(basename "$d")"
			done
			;;
	esac
}

# Shell integration

# Ask the wrapping shell function to cd here after we exit. For this,
# configure `wt source <shell>` in your shell.
request_cd() {
	mkdir -p "$WT_STATE_DIR"
	printf '%s\n' "$1" >"$WT_STATE_DIR/cd"
}

do_source() {
	state="$WT_STATE_DIR/cd"

	case "${1:-}" in
		bash|zsh)
			cat <<-EOF
				wt() {
					command wt "\$@" || return
					if [ -f "$state" ]; then
						cd "\$(cat "$state")" && rm -f "$state"
					fi
				}
			EOF
			;;

		fish)
			cat <<-EOF
				function wt
					command wt \$argv; or return
					if test -f "$state"
						cd (cat "$state"); and rm -f "$state"
					end
				end
			EOF
			;;

		*) err "source: unknown shell '${1:-}' (bash|zsh|fish)" ;;
	esac
}

case "${1:-}" in
	""|-h|--help) usage ;;
	co|checkout) shift; do_checkout "$@" ;;
	ls|list) shift; do_list "$@" ;;
	rm|remove) shift; do_remove "$@" ;;
	prune|pr) shift; do_prune "$@" ;;
	launch) shift; do_launch "$@" ;;
	setup) do_run_hook setup ;;
	teardown) do_run_hook teardown ;;
	source) shift; do_source "$@" ;;
	complete) shift; do_complete "$@" ;;
	completions) shift; do_completions "$@" ;;
	*) err "unknown subcommand '$1'" ;;
esac
