#!/bin/sh -eu
# Simple wrapper to launch sway.

if [ -z "$XDG_RUNTIME_DIR" ]; then
  runtime_dir="/tmp/runtime/$(whoami)"

  mkdir -p "$runtime_dir"
  chmod 700 "$runtime_dir"
  export XDG_RUNTIME_DIR="$runtime_dir"
fi

. "$XDG_CONFIG_HOME/sway/env"

# WOB
if [ -e "$WOB_SOCK" ]; then
  rm -f "$WOB_SOCK"
fi

mkfifo "$WOB_SOCK"

randomize-wallpaper

exec dbus-run-session /usr/bin/sway

