#!/bin/sh -eu
# CLI for playing internet radio.

required mpv

usage() {
  echo "Usage: $(basename "$0") <list|play <id>|stop>"
  echo
  exit 0
}

PID_FILE="/tmp/radio_pid"

stop_playback() {
  if [ -f "$PID_FILE" ]; then
    pid=$(cat "$PID_FILE")
    if [ -n "$pid" ] && ps p "$pid" > /dev/null; then
      kill "$pid"
      rm "$PID_FILE"
      echo "Stopped existing playback"
    fi
  fi
}

start_playback() {
  name="$(sed -n "${1}p" "${XDG_CONFIG_HOME:-"$HOME/.config"}/stations.tsv" | cut -f 2)"
  url="$(sed -n "${1}p" "${XDG_CONFIG_HOME:-"$HOME/.config"}/stations.tsv" | cut -f 3)"

  if [ -z "$url" ]; then
    err "'$1': no such station"
  fi

  stop_playback
  mpv --cache=yes --cache-secs=5 --demuxer-max-bytes=8192k --no-video --quiet "$url" >/dev/null 2>&1 &
  echo "$!" > "$PID_FILE"
  echo "Playing station '$name'"
}

case "${1:-}" in
  ""|-h|--help) usage ;;
  list) cat "${XDG_CONFIG_HOME:-"$HOME/.config"}/stations.tsv" ;;
  play) start_playback "${2:-1}" ;;
  stop) stop_playback ;;
  *) err "unknown subcommand '$1'" ;;
esac
