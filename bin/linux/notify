#!/bin/sh -eu
# Send a desktop notification.

title="Notification"
urgent=""

usage() {
  echo "Usage: $(basename "$0") [opts] <message>"
  echo
  echo "OPTIONS"
  echo "  -h, --help     Show this help."
  echo "  -t <title>     Notification title. Defaults to 'Notification'."
  echo "  -u             Mark urgent (critical urgency)."
  echo
  exit 0
}

case "${1:-}" in
  -h|--help) usage ;;
esac

while getopts t:uh opt; do
  case "$opt" in
    t) title="$OPTARG" ;;
    u) urgent=1 ;;
    h) usage ;;
    *) exit 2 ;;
  esac
done
shift $((OPTIND - 1))

msg="$*"
[ -n "$msg" ] || err "no message given"

# Terminal bell, best-effort to the controlling terminal.
( printf '\a' >/dev/tty ) 2>/dev/null || true

has notify-send || exit 0

set -- "$title" "$msg"
[ -n "$urgent" ] && set -- -u critical "$@"
notify-send "$@"
