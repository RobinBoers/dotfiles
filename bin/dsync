#!/usr/bin/env bash

if [ $# -lt 2 ]; then
  echo "Usage: $(basename $0) <SOURCE> <DEST> [FLAGS...]" >&2
  exit 0
fi

src="$1"
dest="$2"
shift 2

flags="-ciavuP --delete --exclude .git --exclude Bakefile"
preview=$(rsync -n $flags "$src" "$dest" "$@" 2>&1 | grep -v '^\.[fd]\.\.t')

if [ -z "$preview" ]; then
  echo "Nothing to sync."
  exit 0
fi

echo "$preview"
echo

if prompt -n "Proceed?"; then
  rsync $flags "$src" "$dest" "$@"
else
  echo "Aborted."
  exit 1
fi
