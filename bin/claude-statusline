#!/bin/sh

input=$(cat)

# jq emits four NUL-free lines: left plain, left colored, right plain, right
# colored. Plain variants are used only to measure visible width for padding.
fields=$(printf '%s' "$input" | jq -r '
  def kfmt: if . == null then "0"
            elif . >= 1000 then ((. / 100 | round) / 10 | tostring) + "k"
            else (. | floor | tostring) end;
  def dur: ((. // 0) / 1000 | floor) as $s |
           if   $s >= 3600 then "\($s/3600|floor)h\((($s%3600)/60)|floor)m"
           elif $s >= 60   then "\($s/60|floor)m\($s%60)s"
           else "\($s)s" end;
  def usd: ((. // 0) * 100 | round) as $c
           | "$" + ($c / 100 | floor | tostring) + "."
           + (($c % 100) as $cc | if $cc < 10 then "0\($cc)" else "\($cc)" end);

  "[0m"  as $r  |
  "[1m"  as $b  | "[2m"  as $dim  |

  (.cwd // .workspace.current_dir // "")                          as $cwd
  | ($cwd | split("/") | map(select(. != "")) | .[-2:] | join("/")) as $path
  | (.model.display_name // "?")                                 as $model
  | (.effort.level // "")                                        as $eff
  | (if $eff == "" then "" else " (" + $eff + ")" end)           as $effp
  | (.cost.total_duration_ms | dur)                              as $time
  | ((.context_window.total_input_tokens // 0) | kfmt)          as $cu
  | ((.context_window.context_window_size // 0) | kfmt)         as $ct
  | (.cost.total_cost_usd | usd)                                 as $cost
  | ((.transcript_path // "") | (match("/claude/([^/]+)/projects/") | .captures[0].string) // "")
                                                                 as $persona

  | ("[" + $path + "] " + $model + $effp)                          as $lplain
  | ($b + "[" + $path + "] " + $r + $model
        + $dim + $effp + $r)                                      as $lcol
  | ($time + " | " + $cu + "/" + $ct + " | " + $cost)              as $rplain
  | ($dim + $time + " | " + $cu + "/" + $ct + " | " + $cost + $r)  as $rcol

  | $lplain, $lcol, $rplain, $rcol, $persona
')

# IFS= keeps any leading escape/space intact; one read per emitted line.
{
  IFS= read -r lplain
  IFS= read -r lcol
  IFS= read -r rplain
  IFS= read -r rcol
  IFS= read -r persona
} <<EOF
$fields
EOF

# Claude reports the full terminal width in COLUMNS but draws the statusline
# inset by ~2 columns on each side, so the real drawable area is COLUMNS - 4.
# Pad to that, else the right block runs under the inset and gets truncated.
cols=${COLUMNS:-80}
reserve=4

if [ -n "$persona" ] && [ "$cols" -ge 100 ]; then
  rplain="${persona}  ${rplain}"
  rcol="${persona}  ${rcol}"
fi

pad=$((cols - reserve - ${#lplain} - ${#rplain}))
[ "$pad" -lt 1 ] && pad=1

# %*s renders `pad` spaces; colored ends are printed verbatim around them.
printf '%s%*s%s\n' "$lcol" "$pad" "" "$rcol"
