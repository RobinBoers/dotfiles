#!/bin/sh
# Send a desktop notification.

set -eu

title="Notification"
urgent=""
sound="Glass"	# played only when urgent

usage() {
	echo "Usage: $(basename "$0") [-u] [-t TITLE] MESSAGE"
	echo
	echo "OPTIONS"
	echo "  -h, --help     Show this help."
	echo "  -t TITLE       Notification title. Defaults to 'Notification'."
	echo "  -u             Mark urgent (plays a sound)."
	echo
	exit 0
}

case "${1:-}" in
	-h|--help) usage ;;
esac

while getopts t:uh opt; do
	case "$opt" in
		t) title="$OPTARG" ;;
		u) urgent=1 ;;
		h) usage ;;
		*) exit 2 ;;
	esac
done
shift $((OPTIND - 1))

msg="$*"
[ -n "$msg" ] || err "no message given"

# Terminal bell, best-effort to the controlling terminal.
( printf '\a' >/dev/tty ) 2>/dev/null || true

# Pass title/message/sound as argv to sidestep AppleScript string escaping.
osascript - "$title" "$msg" "${urgent:+$sound}" <<-'EOF'
	on run argv
		set t to item 1 of argv
		set m to item 2 of argv
		set s to item 3 of argv
		if s is "" then
			display notification m with title t
		else
			display notification m with title t sound name s
		end if
	end run
EOF
