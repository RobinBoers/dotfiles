#!/bin/sh -eu
# Claude Code hook to send desktop notifications.

payload="$(cat)"

field() { printf '%s' "$payload" | jq -r "$1 // empty"; }

event="$(field '.hook_event_name')"
cwd="$(field '.cwd')"
msg="$(field '.message')"

# the worktree/repo leaf tells parallel sessions apart at a glance.
ctx="$(basename "${cwd:-$PWD}")"

case "$event" in
	Notification) notify -u -t "Claude @ $ctx" "${msg:-Claude needs your attention.}" ;;
	Stop|SubagentStop) notify -t "Claude @ $ctx" "Claude is done, take a look." ;;
	*) notify -t "Claude @ $ctx" "${msg:-$event}" ;;
esac
