#!/usr/bin/env bash
# Shitty bash-based Makefile replacement.

set -eu

PATH="./node_modules/.bin:$PATH"

usage() {
  echo "Usage: $(basename "$0") <target> [args]"
  echo
  exit 0
}

if [ -e "./Bakefile" ]; then
  source ./Bakefile
else
  case ${1:-} in
    -h|--help|help) usage ;;
  esac

  err "no Bakefile found"
fi

help() {
  echo "Usage: $(basename "$0") <target> [args]"
  echo
  echo "TARGETS"

  compgen -A function | grep -v '^p:' | grep -v '^help$' | grep -v '^usage$' | cat -n

  echo
  exit 0
}

case ${1:-} in
  -h|--help|help)
    help
    ;;
  "")
    if help | grep "build" -q; then
      TARGET=build build
    else
      err "build: no such target"
    fi
    ;;
  *)
    if help | grep "$1" -q; then
      set -o pipefail
      TARGET=$1 ${@}
    else
      err "$1: no such target"
    fi
    ;;
esac
